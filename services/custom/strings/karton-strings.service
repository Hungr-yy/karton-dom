[Unit]
Description=Karton strings extractor
After=network.target

[Service]
Environment=KARTON_CONFIG_PATH=/etc/karton/karton.ini
Type=simple
WorkingDirectory=/opt/karton-custom/services/custom/strings
ExecStart=/opt/karton-workers-venv/bin/python /opt/karton-custom/services/custom/strings/karton-strings.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
