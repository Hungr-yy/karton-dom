[Unit]
Description=Karton capa MITRE ATT&CK capability analyzer
After=network.target

[Service]
Environment=KARTON_CONFIG_PATH=/etc/karton/karton.ini
Type=simple
WorkingDirectory=/opt/karton-custom/services/custom/capa
ExecStart=/opt/karton-workers-venv/bin/python /opt/karton-custom/services/custom/capa/karton-capa.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
